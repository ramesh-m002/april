$search_id = 'ABC123';

$pages = get_posts(array(
    'post_type' => 'page',
    'posts_per_page' => -1
));

foreach ($pages as $page) {

    if (have_rows('simulator_links', $page->ID)) {

        while (have_rows('simulator_links', $page->ID)) {
            the_row();

            if (get_sub_field('simulator_id') == $search_id) {
                echo get_the_title($page->ID);
                break;
            }
        }

    }
}
