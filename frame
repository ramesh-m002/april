<?php
/**
 * Course Search Toggle - Switch between legacy PHP and Flutter iframe versions
 */

// Admin setting to toggle between versions
add_action('admin_init', function () {
  register_setting('general', 'course_search_use_flutter', [
    'type' => 'boolean',
    'default' => false,
    'sanitize_callback' => 'rest_sanitize_boolean',
  ]);
  add_settings_field(
    'course_search_use_flutter',
    'Use Flutter Course Search',
    function () {
      $val = get_option('course_search_use_flutter');
      echo '<input type="checkbox" name="course_search_use_flutter" value="1" ' . checked(1, $val, false) . '>';
      echo '<p class="description">Check to use the new Flutter-based course search instead of the legacy version.</p>';
    },
    'general'
  );
});

// Handle QA override via query params (?cs=flutter or ?cs=legacy)
add_action('init', function () {
  if (!isset($_GET['cs'])) return;

  $choice = sanitize_key($_GET['cs']);
  if ($choice === 'flutter') {
    setcookie('cs_override', 'flutter', time() + 30 * DAY_IN_SECONDS, COOKIEPATH, COOKIE_DOMAIN, is_ssl(), true);
  } elseif ($choice === 'legacy') {
    setcookie('cs_override', '', time() - 3600, COOKIEPATH, COOKIE_DOMAIN, is_ssl(), true);
  }
});

// Check if override is active (for QA/testing)
function course_search_override_active() {
  // Cookie override
  if (!empty($_COOKIE['cs_override']) && $_COOKIE['cs_override'] === 'flutter') {
    return true;
  }
  // Role-based: auto-enable for logged-in editors/admins during rollout
  if (is_user_logged_in() && current_user_can('edit_posts')) {
    // Uncomment to force-on for staff:
    // return true;
  }
  return false;
}

// Main URL router function
function course_search_url() {
  // Per-user/cookie override wins over the global toggle
  if (course_search_override_active()) {
    return home_url('/course-search-flutter/');
  }
  return get_option('course_search_use_flutter')
    ? home_url('/course-search-flutter/')
    : home_url('/course-search/');
}

// Automatically rewrite nav menu links with 'course-search-link' CSS class
add_filter('nav_menu_link_attributes', function ($atts, $item) {
  if (in_array('course-search-link', (array) $item->classes, true)) {
    $atts['href'] = esc_url(course_search_url());
  }
  return $atts;
}, 10, 2);




